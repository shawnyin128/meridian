{
  "name": "meridian-research-graph",
  "displayName": "Meridian Research Graph",
  "description": "Read-only Meridian Lab research graph viewer.",
  "version": "0.8.0",
  "publisher": "meridian",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shawnyin128/meridian.git",
    "directory": "plugins/vscode/meridian-research-graph"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onCommand:meridian.openResearchGraph",
    "workspaceContains:.meridian/graph/graph.json"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist/**",
    "package.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "meridian.openResearchGraph",
        "title": "Meridian: Open Research Graph"
      },
      {
        "command": "meridian.refreshResearchGraph",
        "title": "Meridian: Refresh Research Graph"
      },
      {
        "command": "meridian.checkResearchGraph",
        "title": "Meridian: Check Research Graph"
      },
      {
        "command": "meridian.revealSelectedNodeMarkdown",
        "title": "Meridian: Reveal Selected Node Markdown"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.extension.json && vite build",
    "test": "vitest run"
  },
  "dependencies": {
    "@xyflow/react": "^12.8.4",
    "antd": "^5.26.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.2",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^24.1.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vitest": "^1.6.1"
  }
}
