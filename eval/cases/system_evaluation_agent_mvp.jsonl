{"id":"system_eval_research_retrieval_context","category":"system_evaluation_agent_mvp","query":"I want to compare long-context KV-cache compression mechanisms and identify failure boundaries before designing a new experiment.","intent":"research query -> retrieval context","problem_description":"The evaluator should judge whether retrieval returns compiled synthesis/topic/method/concept context plus source paper provenance for a realistic research comparison.","required_page_families":["corpus:syntheses","type:concept","type:paper"],"required_section_groups":[{"id":"synthesis_structure","page_families":["corpus:syntheses"],"sections":["Source Facts","Wiki Synthesis","Evidence Map","Open Questions"]},{"id":"concept_coding_context","page_families":["type:concept"],"sections":["Implementation Implications","Minimal Checks / Probes","Evidence / Provenance"]}],"expected_context_properties":["compiled context before paper dump","source provenance visible","uncertainty and failure boundaries explicit"],"acceptable_paths":["type:method","type:topic","type:evidence"],"must_not_do":["return draft/debug artifacts as product context","treat user insight as paper evidence"],"rubric":["task usefulness","retrieval context quality","compiled knowledge density","provenance"]}
{"id":"system_eval_coding_probe_context","category":"system_evaluation_agent_mvp","query":"Before coding a speculative decoding probe, retrieve the method, prerequisite concepts, evidence, and sanity checks I should read.","intent":"coding/probe query -> method + concept + evidence","problem_description":"The evaluator should check whether coding-oriented retrieval includes method hooks, preliminary concepts, evidence, and minimal checks.","required_page_families":["type:method","type:concept","type:evidence"],"required_section_groups":[{"id":"method_hooks","page_families":["type:method"],"sections":["Implementation Hooks","Prerequisite Concepts"]},{"id":"concept_checks","page_families":["type:concept"],"sections":["Common Failure Modes","Minimal Checks / Probes","Implementation Implications"]},{"id":"evidence_trace","page_families":["type:evidence"],"sections":["Evidence Item","Source","Metric or Observation","Provenance"]}],"expected_context_properties":["coding-relevant concept pages","method hooks","traceable evidence"],"acceptable_paths":["corpus:syntheses","type:paper","type:claim"],"must_not_do":["return only papers","hide provenance"],"rubric":["concept usefulness","claim/evidence support","task usefulness"]}
{"id":"system_eval_claim_support_trace","category":"system_evaluation_agent_mvp","query":"Check whether preference optimization evidence really supports this research direction, and keep unsupported claims separate.","intent":"claim support check -> claim/evidence/provenance","problem_description":"The evaluator should verify that claim/evidence retrieval separates source evidence, wiki synthesis, and uncertainty.","required_page_families":["type:claim","type:evidence"],"required_section_groups":[{"id":"claim_support","page_families":["type:claim","type:evidence"],"sections":["Claim","Supporting Evidence","Evidence Item","Provenance","Reliability"]}],"expected_context_properties":["claim support visible","source papers traceable","uncertainty surfaced"],"acceptable_paths":["corpus:syntheses","type:concept","type:paper"],"must_not_do":["promote source-quality hold as evidence","use user insight as source fact"],"rubric":["claim/evidence support quality","boundary correctness","traceability"]}
{"id":"system_eval_user_insight_retrieval","category":"system_evaluation_agent_mvp","query":"Use my reading insight about a paper to retrieve relevant context for a future implementation idea, while labeling it as user-supplied.","intent":"user insight affects retrieval","problem_description":"The evaluator should check that personalization is useful but not confused with paper source facts.","required_page_families":["type:paper"],"required_section_groups":[{"id":"insight_context","page_families":["type:paper"],"sections":["User Insights","Retrieval Hooks","Implementation Hooks"]}],"expected_context_properties":["user insight labeled","raw note preserved or traceable","paper source facts separate"],"acceptable_paths":["corpus:syntheses","type:method","type:concept"],"must_not_do":["mix user insight into source facts"],"rubric":["personalization boundary","retrieval usefulness","entry consistency"]}
{"id":"system_eval_synthesis_writeback_quality","category":"system_evaluation_agent_mvp","query":"Preserve a useful comparison answer as a synthesis page that I can retrieve later.","intent":"synthesis write-back quality","problem_description":"The evaluator should assess proposal or synthesis output for source fact / synthesis / user idea separation and durable retrieval hooks.","required_page_families":["corpus:syntheses"],"required_section_groups":[{"id":"writeback_contract","page_families":["corpus:syntheses"],"sections":["Source Facts","Wiki Synthesis","Evidence Map","Open Questions","Retrieval Hooks"]}],"expected_context_properties":["durable synthesis shape","evidence map","future retrieval hooks"],"acceptable_paths":["type:paper","type:claim","type:evidence"],"must_not_do":["publish unsupported source facts","omit provenance"],"rubric":["synthesis quality","provenance","optimization actionability"]}
{"id":"system_eval_entry_boundary","category":"system_evaluation_agent_mvp","query":"Use the Prompt or MCP entry to answer a research question without exposing internal debug artifacts.","intent":"MCP/Prompt entry boundary","problem_description":"The evaluator should catch product-boundary failures and verify that Prompt/MCP entries use canonical context only.","required_page_families":["type:paper"],"required_section_groups":[],"expected_context_properties":["canonical paths only","compact output","next action visible"],"acceptable_paths":["corpus:syntheses","type:method","type:concept","type:claim","type:evidence"],"must_not_do":["return .drafts or .versions","present review.md as user-facing output"],"rubric":["entry consistency","artifact boundary","source/synthesis/user boundary"]}
